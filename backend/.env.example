# 应用配置
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 图片处理
MAX_UPLOAD_SIZE_MB=20
IMAGE_MAX_LONG_EDGE=2048

# 视频临时文件
VIDEO_TEMP_DIR=temp_videos
VIDEO_EXPIRE_SECONDS=3600

# AI 模型 API Keys（按需配置，不配则使用 Mock 模式）
OPENAI_API_KEY=
FAL_API_KEY=
KLING_API_KEY=
PHOTOROOM_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_MODEL_ID=doubao-seedream-4-5-251128

# 模型默认配置
DEFAULT_IMAGE_MODEL=gpt-image-2
